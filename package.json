{
  "devDependencies": {
    "concurrently": "^9.2.1",
    "deepl-node": "^1.24.0",
    "sync-studio": "file:../sync-studio"
  },
  "scripts": {
    "sync": "sync-studio",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run translate:watch\" \"npm run readme:watch\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "translate": "node scripts/translate.js",
    "translate:watch": "node scripts/translate.js --watch",
    "readme": "node scripts/readme.js",
    "readme:check": "node scripts/readme.js --check",
    "readme:watch": "node scripts/readme.js --watch"
  }
}
